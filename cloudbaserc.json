{
  "envId": "rosa-env-d7grf78r5dbd37323",
  "functionRoot": "cloudfunctions",
  "functions": [
    {
      "name": "petTower-api",
      "handler": "index.main",
      "runtime": "Nodejs18.15",
      "timeout": 15,
      "memorySize": 256,
      "installDependency": true,
      "ignore": [
        "node_modules/**",
        "config.env",
        ".env",
        "*.local"
      ]
    },
    {
      "name": "analytics-ingest",
      "type": "Event",
      "handler": "index.main",
      "timeout": 10,
      "runtime": "Nodejs18.15",
      "memorySize": 256,
      "installDependency": true,
      "envVariables": {
        "ANALYTICS_COLLECTION": "analytics_events",
        "ANALYTICS_GAME_KEYS": "hotpot,huahua,caizhu,xiaochu,petTower,petTower_tt"
      }
    }
  ]
}