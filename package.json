{
  "name": "xiaochu2",
  "version": "0.1.0",
  "type": "module",
  "description": "灵宠消消塔 2 - 转珠消除+灵宠养成小游戏（微信/抖音）",
  "scripts": {
    "build": "vite build && rimraf minigame/index.html && node scripts/rename-creature-assets.mjs && node scripts/organize-subpackages.mjs",
    "assets:rename-creatures": "node scripts/rename-creature-assets.mjs",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "balance:dashboard": "vite --config tools/balance-dashboard/vite.config.ts",
    "balance:dashboard:build": "vite build --config tools/balance-dashboard/vite.config.ts",
    "balance:dashboard:start": "./tools/balance-dashboard/start.sh start",
    "balance:dashboard:stop": "./tools/balance-dashboard/start.sh stop",
    "balance:dashboard:status": "./tools/balance-dashboard/start.sh status",
    "balance:dashboard:install": "./tools/balance-dashboard/start.sh install"
  },
  "dependencies": {
    "@gp/analytics-sdk": "file:../game-analysis/packages/analytics-sdk",
    "@pixi/unsafe-eval": "^7.3.2",
    "pixi.js": "^7.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  }
}
